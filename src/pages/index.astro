---
import "@fontsource-variable/inter";
const siteUrl = "https://akshay-portfolio.vercel.app";
const title = "Akshay Mhatre - Frontend Developer";
const description =
  "Akshay Mhatre is a frontend developer focused on digital banking, building features across retail, business, and wealth management with Angular and the Backbase AI-powered banking platform.";
const ogImage = `${siteUrl}/portfolio-screenshot.png`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={siteUrl} />

    <!-- Primary meta -->
    <meta name="description" content={description} />
    <meta name="author" content="Akshay Mhatre" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={siteUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:site_name" content="Akshay Mhatre" />
    <meta property="og:locale" content="en_US" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- JSON-LD: Person -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Person",
      "name": "Akshay Mhatre",
      "url": siteUrl,
      "jobTitle": "Frontend Developer",
      "sameAs": [
        "https://github.com/akshay3001",
        "https://in.linkedin.com/in/akshay-mhatre-732a83144"
      ]
    })} />

    <!-- Google tag (gtag.js) -->
    <script
      type="text/partytown"
      src="https://www.googletagmanager.com/gtag/js?id=G-HJJ63FZP1P"
    ></script>
    <script type="text/partytown">
      window.dataLayer = window.dataLayer || [];
      function gtag() {
        dataLayer.push(arguments);
      }
      gtag("js", new Date());
      gtag("config", "G-HJJ63FZP1P");
    </script>
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main id="main-content">
      <div class="container">
        <span class="greeting">Hello there</span>
        <h1 class="name" data-testid="personal-info">Akshay</h1>
        <p class="role" aria-label="Backbase Certified Frontend Developer">Backbase Certified<br />Frontend Developer</p>
        <nav class="links" aria-label="Social profiles">
          <ul>
            <li>
              <a
                href="https://github.com/akshay3001"
                target="_blank"
                rel="noopener noreferrer"
                data-testid="github-link"
                aria-label="GitHub profile (opens in new tab)">GitHub</a
              >
            </li>
            <li>
              <a
                href="https://in.linkedin.com/in/akshay-mhatre-732a83144"
                target="_blank"
                rel="noopener noreferrer"
                data-testid="linked-link"
                aria-label="LinkedIn profile (opens in new tab)">LinkedIn</a
              >
            </li>
          </ul>
        </nav>
        <p class="bio">
          Frontend developer focused on digital banking. I work with Angular and
          the Backbase AI-powered banking platform to build and ship features across retail,
          business, and wealth management - from onboarding to servicing,
          covering the full customer lifecycle.
        </p>
      </div>
    </main>
  </body>
</html>

<style>
  :root {
    --bg: #090909;
    --fg: #f0f0f0;
    --white: #fff;
    --muted-1: #222;
    --muted-2: #2a2a2a;
    --muted-3: #999;
    --muted-4: #888;
    --muted-5: #aaa;
    --muted-6: var(--muted-4);
  }
  .skip-link {
    position: absolute;
    top: -40px;
    left: 0;
    padding: 0.5rem 1rem;
    background: var(--white);
    color: var(--bg);
    font-size: 0.875rem;
    font-weight: 600;
    text-decoration: none;
    z-index: 100;
    transition: top 0.2s;
  }
  .skip-link:focus-visible {
    top: 0;
  }
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }
  html,
  body {
    min-height: 100vh;
    background: var(--bg);
    color: var(--fg);
    font-family: "Inter Variable", sans-serif;
  }
  main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    padding: clamp(2rem, 8vw, 6rem);
  }
  .container {
    max-width: 1000px;
  }
  .greeting {
    display: block;
    font-size: 0.85rem;
    font-weight: 300;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--muted-4);
    margin-bottom: 0.75rem;
  }
  .name {
    font-size: clamp(5rem, 14vw, 11rem);
    font-weight: 900;
    line-height: 0.88;
    letter-spacing: -0.04em;
    color: var(--white);
  }
  .role {
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    font-weight: 300;
    color: var(--muted-5);
    line-height: 1.7;
    margin-top: 2rem;
    padding-left: 1.25rem;
    border-left: 1px solid var(--muted-2);
  }
  .links {
    display: flex;
    gap: 2.5rem;
    margin-top: 4rem;
    align-items: center;
  }
  .links ul {
    display: flex;
    gap: 2.5rem;
    align-items: center;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  a {
    color: var(--muted-6);
    text-decoration: none;
    font-size: 0.8rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    transition: color 0.2s;
    position: relative;
  }
  a::after {
    content: "";
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--white);
    transition: width 0.3s ease;
  }
  a:hover {
    color: var(--white);
  }
  a:hover::after,
  a:focus-visible::after {
    width: 100%;
  }
  a:focus-visible {
    color: var(--white);
    outline: 2px solid var(--white);
    outline-offset: 4px;
    border-radius: 2px;
  }
  .links::before {
    content: "";
    display: block;
    width: 40px;
    height: 1px;
    background: var(--muted-1);
    flex-shrink: 0;
  }
  .bio {
    margin-top: 4rem;
    max-width: 560px;
    font-size: 0.85rem;
    font-weight: 300;
    color: var(--muted-3);
    line-height: 1.8;
  }
</style>
